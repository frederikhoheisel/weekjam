[ext_resource type="Shader" path="res://src/drone/drone_thruster.gdshader" id="2_ysse6"]

[sub_resource type="GDScript" id="GDScript_naubj"]
script/source = "extends Node3D


@onready var mesh_instance_3d: MeshInstance3D = $MeshInstance3D
@onready var gpu_particles_3d: GPUParticles3D = $GPUParticles3D
@onready var spot_light_3d: SpotLight3D = $SpotLight3D


var is_on: bool = false
var tween: Tween


func turn_on() -> void:
	if tween:
		tween.kill()
	tween = create_tween()
	tween.set_parallel(true)
	is_on = true
	
	tween.tween_property(spot_light_3d, \"spot_range\", 2.0, 0.1)
	mesh_instance_3d.show()
	gpu_particles_3d.emitting = true


func turn_off() -> void:
	if tween:
		tween.kill()
	tween = create_tween()
	tween.set_parallel(true)
	is_on = false
	
	tween.tween_property(spot_light_3d, \"spot_range\", 0.0, 0.1)
	mesh_instance_3d.hide()
	gpu_particles_3d.emitting = false


func toggle() -> void:
	if is_on:
		turn_off()
	else:
		turn_on()
"

